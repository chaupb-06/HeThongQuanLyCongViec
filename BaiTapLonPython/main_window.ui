<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>750</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Quản Lý Công Việc - Phạm Bảo Châu</string>
  </property>

  <property name="styleSheet">
   <string>
    QMainWindow {
        background-color: #0d1117;
    }

    QWidget {
        background-color: #0d1117;
        color: #f0f6fc;
        font-family: 'Segoe UI';
        font-size: 10pt;
    }

    QTabWidget#main_tab::pane {
        border: none;
        border-top: 1px solid #1f2937;
        padding-top: 12px;
    }

    QTabWidget#main_tab QTabBar::tab {
        background-color: #161b22;
        color: #8b949e;
        padding: 12px 42px;
        border-radius: 18px;
        margin: 0 6px;
        font-weight: bold;
    }

    QTabWidget#main_tab QTabBar::tab:selected {
        background-color: #00bcd4;
        color: #ffffff;
    }

    QLineEdit, QComboBox, QDateEdit {
        background-color: #161b22;
        border: 1px solid #30363d;
        border-radius: 10px;
        padding: 9px;
        color: white;
    }

    QPushButton {
        border-radius: 16px;
        font-weight: bold;
        font-size: 10pt;
        min-height: 42px;
        padding: 8px 14px;
        color: white;
        border: none;
    }

    QPushButton#btn_add {
        background-color: #14b8a6;
    }
    QPushButton#btn_add:hover {
        background-color: #2dd4bf;
    }

    QPushButton#btn_edit {
        background-color: #3b82f6;
    }
    QPushButton#btn_edit:hover {
        background-color: #60a5fa;
    }

    QPushButton#btn_delete {
        background-color: #ef4444;
    }
    QPushButton#btn_delete:hover {
        background-color: #f87171;
    }

    QPushButton#btn_clear,
    QPushButton#btn_refresh_all {
        background-color: #f59e0b;
        color: #111827;
    }
    QPushButton#btn_clear:hover,
    QPushButton#btn_refresh_all:hover {
        background-color: #fbbf24;
    }

    QPushButton#btn_export {
        background-color: #8b5cf6;
    }
    QPushButton#btn_export:hover {
        background-color: #a78bfa;
    }

    QHeaderView::section {
        background-color: #111827;
        color: #22d3ee;
        font-weight: bold;
        border: none;
        padding: 10px;
    }

    QTableWidget {
        background-color: #161b22;
        gridline-color: #30363d;
        border: none;
        color: white;
        border-radius: 10px;
    }
   </string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout">
    <item>
     <widget class="QTabWidget" name="main_tab">
      <widget class="QWidget" name="tab_manage">
       <attribute name="title">
        <string>QUẢN LÝ</string>
       </attribute>
       <layout class="QVBoxLayout">
        <item>
         <widget class="QLabel">
          <property name="text">
           <string>THÔNG TIN CÔNG VIỆC</string>
          </property>
          <property name="styleSheet">
           <string>font-size: 14pt; font-weight: bold; color: #22d3ee; margin-bottom: 10px;</string>
          </property>
         </widget>
        </item>

        <item>
         <layout class="QFormLayout">
          <item row="0" column="0"><widget class="QLabel"><property name="text"><string>Tên việc:</string></property></widget></item>
          <item row="0" column="1"><widget class="QLineEdit" name="txt_task_name"/></item>

          <item row="1" column="0"><widget class="QLabel"><property name="text"><string>Danh mục:</string></property></widget></item>
          <item row="1" column="1"><widget class="QComboBox" name="combo_category"/></item>

          <item row="2" column="0"><widget class="QLabel"><property name="text"><string>Phụ trách:</string></property></widget></item>
          <item row="2" column="1"><widget class="QComboBox" name="combo_user"/></item>

          <item row="3" column="0"><widget class="QLabel"><property name="text"><string>Trạng thái:</string></property></widget></item>
          <item row="3" column="1"><widget class="QComboBox" name="combo_status"/></item>

          <item row="4" column="0"><widget class="QLabel"><property name="text"><string>Ưu tiên:</string></property></widget></item>
          <item row="4" column="1"><widget class="QComboBox" name="combo_priority"/></item>

          <item row="5" column="0"><widget class="QLabel"><property name="text"><string>Hạn chót:</string></property></widget></item>
          <item row="5" column="1">
           <widget class="QDateEdit" name="date_deadline">
            <property name="displayFormat">
             <string>dd/MM/yyyy</string>
            </property>
            <property name="calendarPopup">
             <bool>true</bool>
            </property>
           </widget>
          </item>
         </layout>
        </item>

        <item>
         <layout class="QHBoxLayout">
          <item><widget class="QPushButton" name="btn_add"><property name="text"><string>THÊM MỚI</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_edit"><property name="text"><string>CẬP NHẬT</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_delete"><property name="text"><string>XÓA</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_clear"><property name="text"><string>LÀM TRỐNG</string></property></widget></item>
         </layout>
        </item>
       </layout>
      </widget>

      <widget class="QWidget" name="tab_search">
       <attribute name="title">
        <string>TRA CỨU</string>
       </attribute>
       <layout class="QVBoxLayout">
        <item>
         <layout class="QHBoxLayout">
          <item>
           <widget class="QLineEdit" name="txt_search">
            <property name="placeholderText">
             <string>Tìm theo tên việc hoặc người làm...</string>
            </property>
           </widget>
          </item>
          <item><widget class="QPushButton" name="btn_refresh_all"><property name="text"><string>TẢI LẠI</string></property></widget></item>
          <item><widget class="QPushButton" name="btn_export"><property name="text"><string>XUẤT EXCEL</string></property></widget></item>
         </layout>
        </item>
        <item>
         <widget class="QTableWidget" name="table_tasks"/>
        </item>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
</ui>